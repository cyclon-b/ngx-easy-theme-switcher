{
  "name": "workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:lib": "ng build ngx-easy-theme-switcher",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:lib": "ng test ngx-easy-theme-switcher",
    "test:app": "ng test test-app",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "publish:lib": "npm run build:lib && npm publish dist/ngx-easy-theme-switcher"
  },
  "private": true,
